{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nitekeeper.github.io/agora/plugins.schema.json",
  "title": "Agora Plugin Registry",
  "description": "Source-of-truth registry for the agora Claude Code plugin marketplace. Plugin name uniqueness is enforced by agora:validate at the script level, not by this schema.",
  "type": "object",
  "required": ["marketplace", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL of this schema; referenced for editor tooling."
    },
    "marketplace": {
      "type": "object",
      "description": "Marketplace metadata.",
      "required": ["name", "description", "owner"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "owner": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "description": "Registered plugins. Each plugin's `name` must be unique across the array (enforced by agora:validate).",
      "items": { "$ref": "#/$defs/plugin" }
    }
  },
  "$defs": {
    "plugin": {
      "type": "object",
      "required": [
        "name",
        "repository_url",
        "current_version",
        "current_sha",
        "description",
        "license"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Plugin id following the <owner>-<repo> convention.",
          "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$",
          "minLength": 3
        },
        "repository_url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub HTTPS clone URL ending in .git.",
          "pattern": "^https://github\\.com/[^/]+/[^/]+\\.git$"
        },
        "current_version": {
          "type": "string",
          "description": "Pinned SemVer (optional leading v, optional prerelease, optional build metadata).",
          "pattern": "^v?\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$"
        },
        "current_sha": {
          "type": "string",
          "description": "Pinned 40-char lowercase hex commit SHA.",
          "pattern": "^[0-9a-f]{40}$"
        },
        "description": {
          "type": "string",
          "description": "One-line plugin description.",
          "minLength": 1,
          "maxLength": 280
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier.",
          "enum": [
            "MIT",
            "Apache-2.0",
            "GPL-3.0-only",
            "GPL-2.0-only",
            "LGPL-3.0-only",
            "LGPL-2.1-only",
            "AGPL-3.0-only",
            "BSD-3-Clause",
            "BSD-2-Clause",
            "ISC",
            "MPL-2.0",
            "Unlicense",
            "CC0-1.0"
          ]
        },
        "category": {
          "type": "string",
          "description": "Marketplace category.",
          "enum": [
            "development",
            "productivity",
            "engineering",
            "design",
            "data",
            "product-management",
            "figma",
            "other"
          ]
        },
        "keywords": {
          "type": "array",
          "description": "Search keywords.",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 16,
          "uniqueItems": true
        },
        "author": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 }
          }
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "registered_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
